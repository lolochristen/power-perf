<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PowerPerfApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PowerPerfApp"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable=""
    Title="PowerPerf">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <!-- Tray icon lives outside the visible content -->
    <Grid>
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            ToolTipText="PowerPerf — starting…"
            IconSource="/Assets/PowerPerf.ico"
            ContextMenuMode="SecondWindow"
            MenuActivation="RightClick">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Exit" Click="ExitMenuItem_Click" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Main panel -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*"    />
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Grid Grid.Row="0" Padding="20,36,20,8">
                <TextBlock
                    Text="PowerPerf"
                    FontSize="20"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />

                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">

                    <!-- AC / Battery badge -->
                    <Border
                        x:Name="SourceBadge"
                        CornerRadius="6"
                        Padding="10,4"
                        Background="#28FFFFFF">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <FontIcon
                                x:Name="SourceIcon"
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xE83E;"
                                FontSize="13" />
                            <TextBlock x:Name="SourceText" FontSize="13" Text="AC" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ── Gauge ── -->
            <Grid Grid.Row="1" Height="290">
                <!-- Arc canvas -->
                <Canvas
                    x:Name="GaugeCanvas"
                    Width="300" Height="270"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />

                <!-- Overlaid text, centred on arc centre (cy=160 within 270px canvas = 59%) -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,55,0,0">
                    <TextBlock
                        x:Name="GhzValueText"
                        FontSize="44"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Text="—" />
                    <TextBlock
                        x:Name="GhzSubText"
                        FontSize="13"
                        HorizontalAlignment="Center"
                        Opacity="0.55"
                        Text="GHz" />
                </StackPanel>

                <!-- Boosting spinner (visible only while toggling) -->
                <ProgressRing
                    x:Name="BoostRing"
                    Width="28" Height="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,140,0,0"
                    Visibility="Collapsed"
                    IsActive="True" />
            </Grid>

            <!-- ── Status cards ── -->
            <StackPanel Grid.Row="2" Padding="20,0,20,20" Spacing="8">

                <!-- Power mode -->
                <Border CornerRadius="8" Padding="14,10" Background="#18FFFFFF">
                    <Grid>
                        <TextBlock Text="Power Mode" Opacity="0.55" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="PowerModeText" HorizontalAlignment="Right" FontWeight="SemiBold" Text="—" />
                    </Grid>
                </Border>

                <!-- Boost completed notification -->
                <Border
                    x:Name="BoostDonePanel"
                    CornerRadius="8" Padding="14,10"
                    Background="#1A76B900"
                    BorderBrush="#4076B900"
                    BorderThickness="1"
                    Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#x26A1;" FontSize="16" VerticalAlignment="Center" Foreground="#A8D08D" />
                        <StackPanel Spacing="0">
                            <TextBlock Text="Boost applied" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock x:Name="BoostTimeText" FontSize="11" Opacity="0.6" Text="" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- CPU speed detail -->
                <Border CornerRadius="8" Padding="14,10" Background="#18FFFFFF">
                    <Grid>
                        <TextBlock Text="CPU Speed" Opacity="0.55" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="CpuDetailText" HorizontalAlignment="Right" FontWeight="SemiBold" Text="—" />
                    </Grid>
                </Border>

                <!-- Threshold (editable) -->
                <Border CornerRadius="8" Padding="14,12" Background="#18FFFFFF">
                    <StackPanel Spacing="6">
                        <Grid>
                            <TextBlock
                                Text="Boost Threshold"
                                Opacity="0.55" FontSize="12"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="ThresholdText"
                                HorizontalAlignment="Right"
                                FontWeight="SemiBold"
                                Text="—" />
                        </Grid>
                        <Slider
                            x:Name="ThresholdSlider"
                            Minimum="0.5"
                            Maximum="6.0"
                            StepFrequency="0.1"
                            TickFrequency="0.5"
                            TickPlacement="Outside"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Grid>
</Window>
